# Database
DATABASE_URL=postgresql://user:password@localhost/thepractice_voice

# Redis (for call state, cache)
REDIS_URL=redis://localhost:6379/0

# Acuity Scheduling
ACUITY_API_KEY=your_acuity_api_key
ACUITY_USER_ID=your_user_id
ACUITY_BUSINESS_ID=your_business_id  # optional

# IntakeQ
INTAKEQ_API_KEY=your_intakeq_api_key

# Vapi
VAPI_AUTH_TOKEN=your_vapi_auth_token

# Twilio (for phone calls/transfers)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+15555555555

# Human transfer number
HUMAN_TRANSFER_NUMBER=+15555555556

# Transcript retention (days, 0 = don't store)
TRANSCRIPT_RETENTION_DAYS=0
